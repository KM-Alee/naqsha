{
  "name": "gemini-live-sandbox",
  "model": "gemini",
  "trace_dir": "../.naqsha/traces",
  "tool_root": "../workspace",
  "allowed_tools": null,
  "memory_adapter": "none",
  "auto_approve": false,
  "approval_required_tiers": ["write", "high"],
  "sanitizer_max_chars": 8000,
  "budgets": {
    "max_steps": 16,
    "max_tool_calls": 24,
    "wall_clock_seconds": 180.0,
    "per_tool_seconds": 45.0,
    "max_model_tokens": null
  },
  "gemini": {
    "base_url": "https://generativelanguage.googleapis.com",
    "model": "gemini-2.0-flash-lite",
    "api_key_env": "GEMINI_API_KEY",
    "timeout_seconds": 180
  }
}
